@model List<GuitarVerse.Models.Product>
@{
    ViewData["Title"] = "Compare Gear";
}

<div class="compare-page-wrapper">
    <div class="container-fluid px-4">

        <div class="d-flex justify-content-between align-items-end mb-4 pt-4">
            <div>
                <h5 class="text-danger text-uppercase ls-2 mb-1">GuitarVerse</h5>
                <h1 class="display-5 fw-bold text-white mb-0">Gear Comparison</h1>
            </div>
            @if (Model.Any())
            {
                <!-- СМЕНЕНО ОТ <a> НА <form> ЗА СИГУРНОСТ -->
                <form method="post" asp-controller="Compare" asp-action="ClearAll" onsubmit="return confirm('Are you sure you want to clear the comparison list?');">
                    <button type="submit" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                        <i class="fa-solid fa-trash-can me-2"></i>Clear All
                    </button>
                </form>
            }
        </div>

        @if (!Model.Any())
        {
            <!-- Добавихме d-flex, flex-column, align-items-center, justify-content-center и min-height -->
            <div class="empty-state d-flex flex-column align-items-center justify-content-center text-center" style="min-height: 60vh;">
                <div class="empty-icon-box mb-3">
                    <i class="fa-solid fa-guitar fa-4x text-muted"></i>
                </div>
                <h2 class="text-white mt-2">Your comparison list is empty</h2>
                <p class="text-muted mb-4">Add some axes to the list to see how they stack up.</p>
                <a href="@Url.Action("Index", "Shop")" class="btn btn-danger btn-lg rounded-pill px-5 fw-bold shadow-lg">
                    Browse Products
                </a>
            </div>
        }
        else
        {
            <div class="compare-table-container custom-scrollbar">
                <table class="compare-table">
                    <thead>
                        <tr>
                            <th class="attribute-col-header text-center align-middle">
                                <!-- Махнахме 'small', добавихме 'fw-bold' и зададохме по-голям размер -->
                                <span class="text-muted text-uppercase fw-bold ls-1" style="font-size: 1.1rem;">Product Details</span>
                            </th>
                            @foreach (var p in Model)
                            {
                                <th class="product-col-header">
                                    <div class="product-header-card">
                                        <a href="@Url.Action("Remove", new { id = p.ProductID })" class="btn-remove" title="Remove">
                                            <i class="fa-solid fa-times"></i>
                                        </a>

                                        <a href="@Url.Action("Details", "Shop", new { id = p.ProductID })" class="product-link">
                                            <div class="img-wrapper">
                                                <img src="@p.ImagePath" alt="@p.Name">
                                            </div>
                                            <div class="product-info">
                                                <span class="brand-badge">@p.Brand</span>
                                                <h5 class="product-title">@p.Name</h5>
                                                <div class="price-tag">@p.Price.ToString("N0") €</div>
                                            </div>
                                        </a>

                                        <div class="mt-3">
                                            <form method="post" asp-controller="Cart" asp-action="AddToCart">
                                                <input type="hidden" name="productId" value="@p.ProductID" />
                                                <input type="hidden" name="quantity" value="1" />

                                                @if (p.Stock > 0)
                                                {
                                                    <button class="btn btn-danger w-100 rounded-pill fw-bold btn-add-cart">
                                                        Add to Cart
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-secondary w-100 rounded-pill fw-bold" disabled>
                                                        Sold Out
                                                    </button>
                                                }
                                            </form>
                                        </div>
                                    </div>
                                </th>
                            }
                        </tr>
                    </thead>

                    <tbody>
                        <tr class="section-row">
                            <td colspan="@(Model.Count + 1)">Key Features</td>
                        </tr>
                        <tr>
                            <td class="label-cell">Category</td>
                            @foreach (var p in Model)
                            {
                                <td>@p.Category.Name</td>
                            }
                        </tr>
                        <tr>
                            <td class="label-cell">Type / Shape</td>
                            @foreach (var p in Model)
                            {
                                <td>@(p.SubType ?? "—")</td>
                            }
                        </tr>
                        <tr>
                            <td class="label-cell">Orientation</td>
                            @foreach (var p in Model)
                            {
                                <td>@(p.Orientation ?? "—")</td>
                            }
                        </tr>

                        <tr class="section-row">
                            <td colspan="@(Model.Count + 1)">Hardware & Electronics</td>
                        </tr>
                        <tr>
                            <td class="label-cell">Number of Strings</td>
                            @foreach (var p in Model)
                            {
                                <td>@(p.NumberOfStrings?.ToString() ?? "—")</td>
                            }
                        </tr>
                        <tr>
                            <td class="label-cell">Pickups Configuration</td>
                            @foreach (var p in Model)
                            {
                                <td>@(p.PickupType ?? "—")</td>
                            }
                        </tr>
                        <tr>
                            <td class="label-cell">Bridge / Tremolo</td>
                            @foreach (var p in Model)
                            {
                                <td>@(p.BridgeType ?? "—")</td>
                            }
                        </tr>

                        <!-- БУТОН ЗА ПОКАЗВАНЕ/СКРИВАНЕ -->
                        <tr>
                            <td colspan="@(Model.Count + 1)" class="text-center py-4" style="background-color: #000; border-bottom: none;">
                                <button type="button" id="toggleSpecsBtn" class="btn btn-outline-danger rounded-pill px-4 fw-bold text-uppercase">
                                    Show Detailed Specs <i class="fa-solid fa-chevron-down ms-2"></i>
                                </button>
                            </td>
                        </tr>

                        <!-- СЕКЦИЯТА С ДЕТАЙЛИТЕ (Центрирана, без червена лента) -->
                        <tr class="section-row-centered extra-spec-row">
                            <td colspan="@(Model.Count + 1)">Detailed Specifications</td>
                        </tr>

                        <!-- Самите спецификации -->
                        <tr class="extra-spec-row">

                            <!-- ЛЯВА КОЛОНА: Празна, но пази бордера -->
                            <td class="label-cell align-top" style="background: transparent;">
                                <!-- Оставяме я празна -->
                            </td>

                            <!-- КОЛОНИ ЗА ПРОДУКТИТЕ -->
                            @foreach (var p in Model)
                            {
                                <td class="specs-cell align-top">
                                    @if (!string.IsNullOrEmpty(p.SpecsText))
                                    {
                                        <ul class="specs-list text-start ps-0 m-0">
                                            @foreach (var line in p.SpecsText.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries))
                                            {
                                                <li class="d-flex align-items-start mb-2">
                                                    <i class="fa-solid fa-circle text-danger me-2 mt-2" style="font-size: 5px; flex-shrink: 0;"></i>
                                                    <span>@line.Trim()</span>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <span class="text-muted text-center d-block mt-3">—</span>
                                    }
                                </td>
                            }
                        </tr>
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>