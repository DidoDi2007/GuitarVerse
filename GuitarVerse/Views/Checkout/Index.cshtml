@model GuitarVerse.Models.CheckoutViewModel
@{
    ViewData["Title"] = "Secure Checkout";
}

<div class="checkout-wrapper">
    <div class="container">

        <div class="checkout-header d-flex justify-content-between align-items-center">
            <h2 class="text-uppercase fw-bold m-0">Secure Checkout</h2>
            <span class="text-muted"><i class="fa-solid fa-lock me-2"></i> Encrypted Connection</span>
        </div>

        <!-- ФОРМАТА СОЧИ КЪМ STRIPE ДЕЙСТВИЕТО -->
        <form method="post" asp-action="CreateStripeSession">

            <div class="row">
                <!-- LEFT COLUMN: SHIPPING INFO -->
                <div class="col-lg-8 mb-4">
                    <div class="checkout-card">
                        <h4 class="text-uppercase mb-4 pb-2 border-bottom border-secondary">Shipping Address</h4>

                        <div class="row g-4">
                            <!-- First Name -->
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label">First Name</label>
                                <input asp-for="FirstName" class="form-control" placeholder="John" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>

                            <!-- Last Name -->
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label">Last Name</label>
                                <input asp-for="LastName" class="form-control" placeholder="Doe" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>

                            <!-- Email -->
                            <div class="col-12">
                                <label asp-for="Email" class="form-label">Email Address</label>
                                <input asp-for="Email" type="email" class="form-control" placeholder="john@example.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <!-- Phone -->
                            <div class="col-12">
                                <label asp-for="Phone" class="form-label">Phone Number</label>
                                <input asp-for="Phone" class="form-control" placeholder="+359..." />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>

                            <!-- Address -->
                            <div class="col-12">
                                <label asp-for="Address" class="form-label">Address</label>
                                <input asp-for="Address" class="form-control" placeholder="Street, Number, Apartment..." />
                                <span asp-validation-for="Address" class="text-danger"></span>
                            </div>

                            <!-- City -->
                            <div class="col-md-5">
                                <label asp-for="City" class="form-label">City</label>
                                <input asp-for="City" class="form-control" />
                                <span asp-validation-for="City" class="text-danger"></span>
                            </div>

                            <!-- Country -->
                            <div class="col-md-4">
                                <label asp-for="Country" class="form-label">Country</label>
                                <select asp-for="Country" class="form-control form-select bg-dark text-white border-secondary">
                                    <option value="Bulgaria">Bulgaria</option>
                                    <option value="Germany">Germany</option>
                                    <option value="UK">United Kingdom</option>
                                    <option value="USA">USA</option>
                                </select>
                                <span asp-validation-for="Country" class="text-danger"></span>
                            </div>

                            <!-- Zip -->
                            <div class="col-md-3">
                                <label asp-for="PostalCode" class="form-label">Postal Code</label>
                                <input asp-for="PostalCode" class="form-control" />
                                <span asp-validation-for="PostalCode" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RIGHT COLUMN: PAYMENT ACTION -->
                <div class="col-lg-4">
                    <div class="checkout-card position-sticky" style="top: 100px;">
                        <h4 class="text-uppercase mb-4 pb-2 border-bottom border-secondary">Payment</h4>

                        <p class="text-muted small mb-4">
                            Clicking the button below will redirect you to <strong>Stripe's secure payment page</strong>. You can pay with Visa, Mastercard, Amex, and more.
                        </p>

                        <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-black rounded border border-secondary">
                            <span class="text-muted">Payment Method</span>
                            <div class="text-white">
                                <i class="fa-brands fa-cc-visa fa-lg mx-1"></i>
                                <i class="fa-brands fa-cc-mastercard fa-lg mx-1"></i>
                                <i class="fa-brands fa-cc-amex fa-lg mx-1"></i>
                            </div>
                        </div>

                        <button type="submit" class="btn stripe-btn w-100 py-3 rounded-0 shadow">
                            Proceed to Payment <i class="fa-solid fa-arrow-right ms-2"></i>
                        </button>

                        <div class="text-center mt-3">
                            <a href="@Url.Action("Index", "Cart")" class="text-decoration-none text-muted small hover-white">
                                <i class="fa-solid fa-arrow-left me-1"></i> Back to Cart
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}