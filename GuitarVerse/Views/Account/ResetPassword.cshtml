@model GuitarVerse.Models.ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
}

<div class="d-flex justify-content-center align-items-center auth-container">
    <div class="card p-4 shadow auth-card">
        <h4 class="text-center mb-3">Reset Your Password</h4>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form id="resetPasswordForm" asp-action="ResetPassword" method="post">
            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="Email" />

            <div class="mb-2">
                <label>New Password</label>
                <input type="password" asp-for="NewPassword" id="Password"
                       class="form-control" required data-show-toggle="showPasswordReset" />
            </div>

            <div class="mb-2">
                <label>Confirm New Password</label>
                <input type="password" asp-for="ConfirmPassword" id="ConfirmPassword"
                       class="form-control" required data-show-toggle="showPasswordReset" />
            </div>

            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="showPasswordReset">
                <label class="form-check-label" for="showPasswordReset">
                    Show Password
                </label>
            </div>

            <div id="passwordCriteria" class="text-muted small mb-2">
                Minimum 8 characters, at least one uppercase letter and one number.
            </div>

            <button type="submit" class="btn btn-dark w-100">Reset Password</button>
        </form>
    </div>
</div>
