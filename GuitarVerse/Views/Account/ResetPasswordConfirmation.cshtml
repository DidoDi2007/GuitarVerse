@{
    ViewData["Title"] = "Password Reset Confirmation";
}

<div class="d-flex justify-content-center align-items-center auth-container">
    <div class="card p-4 shadow auth-card">
        <h4 class="text-center mb-3">Password Reset Successful</h4>

        <p class="text-center">
            Your password has been successfully reset.
            You can now
            <a asp-controller="Account" asp-action="Login">log in</a>
            with your new password.
        </p>
    </div>
</div>
