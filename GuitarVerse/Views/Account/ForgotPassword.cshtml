@{
    ViewData["Title"] = "Forgot Password";
}

<div class="forgot-container d-flex justify-content-center align-items-center">
    <div class="forgot-card card p-4 shadow">
        <h5 class="mb-3">Forgot Password</h5>

        <form method="post" asp-action="ForgotPassword">
            <label>Email</label>
            <input type="email" name="email" class="form-control mb-2" required />

            <button type="submit" class="btn btn-dark w-100">Send Reset Link</button>
        </form>

        @if (ViewBag.Message != null)
        {
            <div class="text-success mt-2">@ViewBag.Message</div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="text-danger mt-2">@ViewBag.Error</div>
        }
    </div>
</div>
