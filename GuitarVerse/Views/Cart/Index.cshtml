@model GuitarVerse.Models.CartViewModel

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="cart-wrapper">
    <div class="container">

        <div class="cart-header">
            <h1 class="fw-bold text-uppercase">Shopping Cart</h1>
        </div>

        @if (!Model.CartItems.Any())
        {
            <div class="text-center py-5">
                <i class="fa-solid fa-cart-shopping fa-3x text-muted mb-3"></i>
                <h3 class="text-uppercase">Your cart is empty</h3>
                <p class="text-muted">Looks like you haven't added any gear yet.</p>
                <a href="@Url.Action("Index", "Shop")" class="btn btn-light rounded-0 mt-3 px-5 text-uppercase fw-bold">Start Shopping</a>
            </div>
        }
        else
        {
            <div class="row">
                <!-- CART ITEMS -->
                <div class="col-lg-8">
                    <table class="cart-table">
                        @foreach (var item in Model.CartItems)
                        {
                            <tr class="cart-row">
                                <!-- Image -->
                                <td class="cart-cell" style="width: 100px;">
                                    <img src="@item.Product.ImagePath" class="cart-img" alt="@item.Product.Name">
                                </td>

                                <!-- Name & Brand -->
                                <td class="cart-cell">
                                    <div class="text-muted small text-uppercase">@item.Product.Brand</div>
                                    <div class="fw-bold">@item.Product.Name</div>
                                </td>

                                <!-- Price -->
                                <td class="cart-cell text-end" style="width: 120px;">
                                    @item.Product.Price.ToString("N0") €
                                </td>

                                <!-- Quantity -->
                                <td class="cart-cell text-center" style="width: 140px;">
                                    <div class="d-flex align-items-center justify-content-center gap-2">
                                        <form method="post" asp-action="UpdateQuantity">
                                            <input type="hidden" name="cartItemId" value="@item.CartItemID" />
                                            <input type="hidden" name="change" value="-1" />
                                            <button type="submit" class="quantity-btn"><i class="fa-solid fa-minus"></i></button>
                                        </form>

                                        <span class="fw-bold">@item.Quantity</span>

                                        <form method="post" asp-action="UpdateQuantity">
                                            <input type="hidden" name="cartItemId" value="@item.CartItemID" />
                                            <input type="hidden" name="change" value="1" />
                                            <button type="submit" class="quantity-btn"><i class="fa-solid fa-plus"></i></button>
                                        </form>
                                    </div>
                                </td>

                                <!-- Remove -->
                                <td class="cart-cell text-center" style="width: 60px;">
                                    <a href="@Url.Action("Remove", new { id = item.CartItemID })" class="text-danger">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </table>
                </div>

                <!-- SUMMARY -->
                <div class="col-lg-4 mt-4 mt-lg-0">
                    <div class="summary-box">
                        <h4 class="text-uppercase fw-bold mb-4">Summary</h4>

                        <div class="d-flex justify-content-between mb-2 text-muted">
                            <span>Subtotal</span>
                            <span>@Model.GrandTotal.ToString("N0") €</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4 text-muted">
                            <span>Shipping</span>
                            <span>Free</span>
                        </div>

                        <div class="d-flex justify-content-between mb-4 border-top border-secondary pt-3">
                            <span class="fs-5 fw-bold">Total</span>
                            <span class="fs-4 fw-bold text-success">@Model.GrandTotal.ToString("N0") €</span>
                        </div>

                        <!-- CHECKOUT BUTTON -->
                        <!-- По-късно ще създадем CheckoutController -->
                        <a href="@Url.Action("Index", "Checkout")" class="btn btn-light w-100 py-3 text-uppercase fw-bold rounded-0">
                            Proceed to Checkout
                        </a>

                        <a href="@Url.Action("Index", "Shop")" class="btn btn-outline-secondary w-100 py-3 text-uppercase fw-bold rounded-0">
                            <i class="fa-solid fa-arrow-left me-2"></i> Continue Shopping
                        </a>

                        <div class="mt-3 text-center small text-muted">
                            <i class="fa-solid fa-lock"></i> Secure Checkout
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>