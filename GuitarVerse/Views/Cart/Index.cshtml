@model GuitarVerse.Models.CartViewModel

@{
    ViewData["Title"] = "Shopping Cart";
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning text-center mt-3">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Error"]
        </div>
    }
}

<div class="cart-wrapper">
    <div class="container">

        <div class="cart-header">
            <h1 class="fw-bold text-uppercase">Shopping Cart</h1>
        </div>

        @if (!Model.CartItems.Any())
        {
            <div class="text-center py-5">
                <i class="fa-solid fa-cart-shopping fa-3x text-muted mb-3"></i>
                <h3 class="text-uppercase">Your cart is empty</h3>
                <p class="text-muted">Looks like you haven't added any gear yet.</p>
                <a href="@Url.Action("Index", "Shop")" class="btn btn-light rounded-0 mt-3 px-5 text-uppercase fw-bold">Start Shopping</a>
            </div>
        }
        else
        {
            <div class="row">
                <!-- CART ITEMS -->
                <div class="col-lg-8">
                    <table class="cart-table">
                        @foreach (var item in Model.CartItems)
                        {
                            <tr class="cart-row">
                                <!-- Image -->
                                <td class="cart-cell" style="width: 100px;">
                                    <img src="@item.Product.ImagePath" class="cart-img" alt="@item.Product.Name">
                                </td>

                                <!-- Name & Brand -->
                                <td class="cart-cell">
                                    <div class="text-muted small text-uppercase">@item.Product.Brand</div>
                                    <div class="fw-bold">@item.Product.Name</div>
                                </td>

                                <!-- Price -->
                                <td class="cart-cell text-end" style="width: 120px;">
                                    @item.Product.Price.ToString("N0") €
                                </td>

                                <!-- Quantity -->
                                <td class="cart-cell text-center" style="width: 140px;">
                                    <div class="d-flex align-items-center justify-content-center gap-2">

                                        <!-- MINUS BUTTON -->
                                        <form method="post" asp-action="UpdateQuantity">
                                            <input type="hidden" name="cartItemId" value="@item.CartItemID" />
                                            <input type="hidden" name="change" value="-1" />
                                            <!-- Ако е 1, правим минуса сив, за да не стане 0 -->
                                            <button type="submit" class="quantity-btn" @(item.Quantity <= 1 ? "disabled style='opacity:0.5'" : "")>
                                                <i class="fa-solid fa-minus"></i>
                                            </button>
                                        </form>

                                        <span class="fw-bold">@item.Quantity</span>

                                        <!-- PLUS BUTTON -->
                                        <form method="post" asp-action="UpdateQuantity">
                                            <input type="hidden" name="cartItemId" value="@item.CartItemID" />
                                            <input type="hidden" name="change" value="1" />

                                            <!-- ВАЖНО: Ако количеството е равно на Stock, правим бутона disable -->
                                            <button type="submit" class="quantity-btn" @(item.Quantity >= item.Product.Stock ? "disabled style='opacity:0.5; cursor:not-allowed;'" : "")>
                                                <i class="fa-solid fa-plus"></i>
                                            </button>
                                        </form>
                                    </div>

                                    <!-- Показваме съобщение, ако е достигнат лимита -->
                                    @if (item.Quantity >= item.Product.Stock)
                                    {
                                        <div class="text-danger small mt-1" style="font-size: 0.7rem;">Max stock reached</div>
                                    }
                                </td>

                                <!-- Remove -->
                                <td class="cart-cell text-center" style="width: 60px;">
                                    <a href="@Url.Action("Remove", new { id = item.CartItemID })" class="text-danger">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </table>
                </div>

                <!-- SUMMARY -->
                <div class="col-lg-4 mt-4 mt-lg-0">
                    <div class="summary-box">
                        <h4 class="text-uppercase fw-bold mb-4">Order Summary</h4>

                        <!-- Subtotal -->
                        <div class="d-flex justify-content-between mb-2 text-muted">
                            <span>Subtotal</span>
                            <span>@Model.SubTotal.ToString("N2") €</span>
                        </div>

                        <!-- DISCOUNT SECTION -->
                        @if (Model.DiscountPercent > 0)
                        {
                            <div class="d-flex justify-content-between mb-2 text-success">
                                <span>Discount (@Model.AppliedCode)</span>
                                <span>-@Model.DiscountPercent%</span>
                            </div>
                            <div class="text-end mb-3">
                                <a href="@Url.Action("RemovePromo")" class="text-danger small text-decoration-none">Remove Code</a>
                            </div>
                        }
                        else
                        {
                            <!-- PROMO INPUT FORM -->
                            <form asp-action="ApplyPromo" method="post" class="input-group mb-3">
                                <input type="text" name="code" class="form-control bg-dark text-white border-secondary" placeholder="Promo Code">
                                <button class="btn btn-outline-light" type="submit">Apply</button>
                            </form>
                            @if (TempData["Error"] != null)
                            {
                                <div class="text-danger small mb-2">@TempData["Error"]</div>
                            }
                        }

                        <div class="d-flex justify-content-between mb-4 border-top border-secondary pt-3">
                            <span class="fs-5 fw-bold">Total</span>
                            <span class="fs-4 fw-bold text-success">@Model.GrandTotal.ToString("N2") €</span>
                        </div>

                        <!-- CHECKOUT BUTTON -->
                        <!-- По-късно ще създадем CheckoutController -->
                        <a href="@Url.Action("Index", "Checkout")" class="btn btn-light w-100 py-3 text-uppercase fw-bold rounded-0">
                            Proceed to Checkout
                        </a>

                        <a href="@Url.Action("Index", "Shop")" class="btn btn-outline-secondary w-100 py-3 text-uppercase fw-bold rounded-0">
                            <i class="fa-solid fa-arrow-left me-2"></i> Continue Shopping
                        </a>

                        <div class="mt-3 text-center small text-muted">
                            <i class="fa-solid fa-lock"></i> Secure Checkout
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>