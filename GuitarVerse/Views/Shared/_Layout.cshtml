<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GuitarVerse</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- GuitarVerse Favicon (Centered G) -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 rx=%2220%22 fill=%22%23000000%22 /><text x=%2250%22 y=%2254%22 font-size=%2270%22 font-weight=%22900%22 font-family=%22Arial, sans-serif%22 text-anchor=%22middle%22 dominant-baseline=%22middle%22 fill=%22%23ffffff%22>G</text></svg>">
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GuitarVerse.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body>

    <!-- ==========================================
         HEADER / NAVIGATION (Sticky)
    =========================================== -->
    <header class="fixed-top">
        
        <!-- 1. TOP BAR: Лого, Търсачка, Икони -->
        <nav class="navbar navbar-expand-lg navbar-dark top-header py-2 px-3 px-md-5">
            <div class="container-fluid p-0">

                <!-- Мобилен Hamburger Бутон -->
                <button class="navbar-toggler border-0 shadow-none me-2" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavigation" aria-controls="mainNavigation" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Лого -->
                <a class="navbar-brand logo-text m-0" asp-controller="Home" asp-action="Index">GUITARVERSE</a>

                <!-- Десктоп Търсачка (Скрита на телефон) -->
                <div class="search-container d-none d-lg-block mx-auto">
                    <form asp-controller="Shop" asp-action="Index" method="get" class="d-flex">
                        <input class="form-control search-input" type="search" placeholder="Search for products..." aria-label="Search" name="query">
                        <button class="btn search-btn" type="submit">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </button>
                    </form>
                </div>

                <!-- Икони (Сравнение, Профил, Количка) -->
                <div class="user-actions d-flex align-items-center ms-auto ms-lg-0">
                    
                    <!-- Compare -->
                    <a href="@Url.Action("Index", "Compare")" class="icon-link me-2 me-md-3" title="Compare Gear">
                        <i class="fa-solid fa-scale-balanced"></i>
                    </a>

                    <!-- Profile -->
                    @{ var isLogged = Context.Session.GetInt32("UserID") != null; }
                    @if (isLogged)
                    {
                        <a href="@Url.Action("Index", "Profile")" class="icon-link me-2 me-md-3 position-relative" title="My Profile">
                            <i class="fa-solid fa-user"></i>
                            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-success border border-dark rounded-circle" style="width: 10px; height: 10px;"></span>
                        </a>
                    }
                    else
                    {
                        <a href="@Url.Action("Login", "Account")" class="icon-link me-2 me-md-3" title="Login / Register">
                            <i class="fa-regular fa-user"></i>
                        </a>
                    }

                    <!-- Cart -->
                    <a href="@Url.Action("Index", "Cart")" class="icon-link position-relative" title="Shopping Cart">
                        <i class="fa-solid fa-cart-shopping"></i>
                        <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem; display: none;">0</span>
                    </a>

                </div>
            </div>
        </nav>

        <!-- 2. BOTTOM BAR: Категории (Свива се в мобилното меню) -->
        <div class="collapse d-lg-block bottom-nav bg-black" id="mainNavigation">
            <div class="container-fluid">
                
                <!-- Мобилна Търсачка (Вижда се само на телефон) -->
                <div class="d-block d-lg-none p-3 border-bottom border-secondary">
                    <form asp-controller="Shop" asp-action="Index" method="get" class="d-flex">
                        <input class="form-control bg-dark text-white border-secondary rounded-0" type="search" placeholder="Search..." name="query">
                        <button class="btn btn-outline-light rounded-0" type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
                    </form>
                </div>

                <ul class="nav-links list-unstyled d-flex flex-column flex-lg-row justify-content-center m-0 p-3 p-lg-0">

                    <!-- Guitars -->
                    <li class="nav-item dropdown-hover mb-2 mb-lg-0">
                        <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="1" class="nav-link">
                            GUITARS <i class="fa-solid fa-chevron-down text-muted text-xs ms-1"></i>
                        </a>
                        <div class="dropdown-menu-custom">
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="1">Electric</a>
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="3">Acoustic</a>
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="3" asp-route-query="Classical">Classical</a>
                        </div>
                    </li>

                    <!-- Basses -->
                    <li class="nav-item dropdown-hover mb-2 mb-lg-0">
                        <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="2" class="nav-link">
                            BASS GUITARS <i class="fa-solid fa-chevron-down text-muted ms-1"></i>
                        </a>
                        <div class="dropdown-menu-custom">
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="2" asp-route-strings="4">4-String</a>
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="2" asp-route-strings="5">5-String</a>
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="2" asp-route-strings="6">6-String</a>
                        </div>
                    </li>

                    <!-- Accessories -->
                    <li class="nav-item dropdown-hover mb-2 mb-lg-0">
                        <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="5" class="nav-link">
                            ACCESSORIES <i class="fa-solid fa-chevron-down text-muted ms-1"></i>
                        </a>
                        <div class="dropdown-menu-custom">
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="5" asp-route-subType="Strings">Strings</a>
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="5" asp-route-subType="Picks">Picks</a>
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="5" asp-route-subType="Cables">Cables</a>
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="5" asp-route-subType="Strap">Straps</a>
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="5" asp-route-subType="Case">Cases</a>
                        </div>
                    </li>

                    <!-- Amps -->
                    <li class="nav-item dropdown-hover mb-2 mb-lg-0">
                        <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="4" class="nav-link">
                            AMPS <i class="fa-solid fa-chevron-down text-muted ms-1"></i>
                        </a>
                        <div class="dropdown-menu-custom">
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="4" asp-route-subType="Combo Amp">Combo Amps</a>
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="4" asp-route-subType="Amp Head">Heads</a>
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="4" asp-route-subType="Cabinet">Cabinets</a>
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="4" asp-route-subType="Processor">Processors</a>
                        </div>
                    </li>

                    <!-- Artists -->
                    <li class="nav-item">
                        <a asp-controller="Artists" asp-action="Index" class="nav-link highlight-hover">ARTISTS</a>
                    </li>

                </ul>
            </div>
        </div>
    </header>

    <!-- ==========================================
         MAIN CONTENT
    =========================================== -->
    <div class="main-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- ==========================================
         FOOTER
    =========================================== -->
    <footer class="footer-minimal">
        <div class="container-fluid px-5">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <a asp-controller="Home" asp-action="Index" class="footer-brand-min">GUITARVERSE</a>
                    <div class="footer-copy-min mt-2">
                        &copy; @DateTime.Now.Year All rights reserved.
                    </div>
                </div>
                <div class="col-md-6 text-center text-md-end footer-links-min">
                    <a asp-controller="Support" asp-action="Contact">Contact Support</a>
                    <span class="footer-separator">•</span>
                    <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- ==========================================
         OVERLAYS (Cookies & Compare)
    =========================================== -->
    
    <!-- Cookie Banner -->
    <div id="cookieConsentBanner" class="cookie-banner" style="display: none;">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-9 text-start mb-3 mb-md-0">
                    <h5 class="fw-bold text-uppercase mb-2">
                        <i class="fa-solid fa-cookie-bite text-warning me-2"></i> We use cookies
                    </h5>
                    <p class="m-0 cookie-text">
                        GuitarVerse uses cookies to ensure you get the best experience, including cart functionality and secure checkout.
                        By continuing, you agree to our <a asp-controller="Home" asp-action="Privacy" class="text-white fw-bold">Privacy Policy.</a>
                    </p>
                </div>
                <div class="col-md-3 text-md-end text-center">
                    <button id="acceptCookiesBtn" class="btn btn-light fw-bold text-uppercase px-5 py-3 rounded-0 text-nowrap border-0 shadow">
                        I Agree
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Compare Popup -->
    <div id="comparePopup" class="compare-popup" style="display: none;">
        <div class="compare-popup-header">
            <span class="fw-bold text-uppercase" style="letter-spacing: 1px; font-size: 0.9rem;">
                <i class="fa-solid fa-scale-balanced text-info me-2"></i> Compare
            </span>
            <button type="button" class="btn-close btn-close-white" onclick="closeComparePopup()" style="font-size: 0.7rem;"></button>
        </div>
        <div class="compare-popup-body d-flex align-items-center">
            <div id="compareItemsContainer" class="compare-items-container d-flex gap-3"></div>
            <div class="compare-actions ms-4 ps-4 border-start border-secondary d-flex flex-column justify-content-center align-items-center">
                <a href="@Url.Action("Index", "Compare")" id="btnGoCompare" class="btn btn-light rounded-pill px-4 py-2 fw-bold mb-3 position-relative disabled transition-all">
                    Compare
                    <span id="compareBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.7rem; border: 2px solid #1a1a1a;">0</span>
                </a>
                <button onclick="clearCompare()" class="btn btn-link text-muted p-0 text-decoration-none small" style="font-size: 0.85rem;">
                    <i class="fa-solid fa-trash-can me-1"></i> Delete all
                </button>
            </div>
        </div>
    </div>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        // Код за бисквитките (остава тук, за да зарежда бързо)
        document.addEventListener("DOMContentLoaded", function() {
            if (!localStorage.getItem("guitarverse_cookies_accepted")) {
                document.getElementById("cookieConsentBanner").style.display = "block";
            }
            document.getElementById("acceptCookiesBtn").addEventListener("click", function() {
                localStorage.setItem("guitarverse_cookies_accepted", "true");
                document.getElementById("cookieConsentBanner").style.display = "none";
            });
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>