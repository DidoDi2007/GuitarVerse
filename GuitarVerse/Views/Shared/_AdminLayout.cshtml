@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    // Взимаме ролята директно от сесията
    var userRole = HttpContextAccessor.HttpContext.Session.GetString("UserRole");
    var isSuperAdmin = userRole == "superadmin"; // Проста проверка

    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GuitarVerse Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- ПРОМЯНАТА Е ТУК: Вече сочи към admin.css -->
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body" style="padding-top: 0; background-color: #f4f6f9;">
        
    <div class="admin-wrapper">

        <!-- SIDEBAR -->
        <nav class="admin-sidebar">
            <a href="@Url.Action("Dashboard", "Admin")" class="admin-brand">
                GuitarVerse <span class="text-danger">Admin</span>
            </a>

            <div class="nav flex-column admin-nav">
                <a href="@Url.Action("Dashboard", "Admin")" class="nav-link @(currentAction == "Dashboard" ? "active" : "")">
                    <i class="fa-solid fa-gauge-high"></i> Dashboard
                </a>

                <!-- Ако сме на Products или CreateProduct, бутонът Products свети -->
                <a href="@Url.Action("Products", "Admin")" class="nav-link @(currentAction == "Products" || currentAction == "CreateProduct" ? "active" : "")">
                    <i class="fa-solid fa-guitar"></i> Products
                </a>

                @if (isSuperAdmin)
                {
                    <a href="@Url.Action("Users", "Admin")" class="nav-link @(currentAction == "Users" ? "active" : "")">
                        <i class="fa-solid fa-users"></i> Users
                    </a>
                }

                <a href="@Url.Action("Orders", "Admin")" class="nav-link @(currentAction == "Orders" ? "active" : "")">
                    <i class="fa-solid fa-box-open"></i> Orders
                </a>

                <a href="@Url.Action("Support", "Admin")" class="nav-link @(currentAction == "Support" ? "active" : "")">
                    <i class="fa-solid fa-envelope"></i> Messages
                </a>

                







                <div class="mt-5 border-top border-secondary pt-3 mx-3">
                    <a href="@Url.Action("Index", "Home")" class="nav-link text-muted">
                        <i class="fa-solid fa-arrow-left"></i> Back to Shop
                    </a>
                    <a href="@Url.Action("Logout", "Account")" class="nav-link text-danger">
                        <i class="fa-solid fa-right-from-bracket"></i> Logout
                    </a>
                </div>
            </div>
        </nav>

        <!-- MAIN CONTENT -->
        <main class="admin-content">
            @RenderBody()
        </main>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>