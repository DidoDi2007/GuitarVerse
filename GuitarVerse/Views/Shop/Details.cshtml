@model GuitarVerse.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<div class="details-wrapper">
    <div class="container">

        <!-- BREADCRUMB -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Shop")" class="text-decoration-none text-muted">SHOP</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Shop", new { brand = Model.Brand })" class="text-decoration-none text-muted">@Model.Brand</a></li>
                <li class="breadcrumb-item active text-white" aria-current="page">@Model.Name</li>
            </ol>
        </nav>

        <div class="row">
            <!-- LEFT: GALLERY -->
            <div class="col-lg-8">
                <div class="gallery-container">
                    <!-- Thumbnails -->
                    <div class="thumbnail-list">
                        <!-- Главната снимка винаги е първа -->
                        <img src="@Model.ImagePath" class="thumbnail active" onclick="changeImage(this.src, this)">

                        <!-- Галерията (ако има други снимки) -->
                        @if (Model.Images != null)
                        {
                            // Смени Take(4) на Take(5)
                            foreach (var img in Model.Images.Take(5 ))
                            {
                                <img src="@img.ImagePath" class="thumbnail" onclick="changeImage(this.src, this)">
                            }
                        }
                    </div>

                    <!-- Main Image Display -->
                    <div class="main-image-container">
                        <img src="@Model.ImagePath" id="mainImage" class="main-image" alt="@Model.Name">
                    </div>
                </div>
            </div>

            <!-- RIGHT: INFO & BUY -->
            <div class="col-lg-4 ps-lg-5">
                <div class="brand-label">@Model.Brand</div>
                <h1 class="product-name-large">@Model.Name</h1>

                <!-- ЦЕНА -->
                <div class="product-price-large">
                    @Model.Price.ToString("N0") €
                </div>

                <!-- СТАТУС НА НАЛИЧНОСТ -->
                @if (Model.Stock > 0)
                {
                    <p class="text-success fw-bold text-uppercase mb-4" style="letter-spacing: 1px;">
                        <i class="fa-solid fa-check-circle me-2"></i> In Stock & Ready to Ship
                        <!-- Опционално: Може да покажем колко остават, ако са малко -->
                        @if (Model.Stock < 5)
                        {
                            <span class="text-warning small ms-2">(Only @Model.Stock left!)</span>
                        }
                    </p>

                    <!-- БУТОН (АКТИВЕН) -->
                    <div class="d-grid gap-2 mb-4">
                        <form method="post" asp-controller="Cart" asp-action="AddToCart">
                            <input type="hidden" name="productId" value="@Model.ProductID" />
                            <input type="hidden" name="quantity" value="1" />

                            <button type="submit" class="btn btn-light btn-lg rounded-0 fw-bold py-3 text-uppercase fs-5 w-100">
                                ADD TO CART
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <!-- ИЗЧЕРПАНО (OUT OF STOCK) -->
                    <p class="text-danger fw-bold text-uppercase mb-4" style="letter-spacing: 1px;">
                        <i class="fa-solid fa-circle-xmark me-2"></i> Out of Stock
                    </p>

                    <!-- БУТОН (НЕАКТИВЕН) -->
                    <div class="d-grid gap-2 mb-4">
                        <button class="btn btn-secondary btn-lg rounded-0 fw-bold py-3 text-uppercase fs-5 w-100" disabled>
                            SOLD OUT
                        </button>
                    </div>
                }

                <!-- НОВИЯТ БУТОН ЗА СРАВНЕНИЕ -->
                <button type="button" onclick="addToCompare(@Model.ProductID)" class="btn btn-outline-info rounded-0 text-uppercase fw-bold w-100 mb-2">
                    <i class="fa-solid fa-scale-balanced me-2"></i> Add to Compare
                </button>

                <a href="@Url.Action("Index", "Shop")" class="btn btn-outline-secondary rounded-0 text-uppercase w-100">
                    Back to Shop
                </a>

                <ul class="list-unstyled feature-list mt-4">

                    <!-- 1. ОБЩИ ДАННИ -->
                    <li>
                        <div class="feature-icon"><i class="fa-solid fa-tag"></i></div>
                        <strong>Brand:</strong>&nbsp; @Model.Brand
                    </li>
                    <li>
                        <div class="feature-icon"><i class="fa-solid fa-barcode"></i></div>
                        <strong>Model:</strong>&nbsp; @Model.Name
                    </li>

                    <!-- 2. ПРОВЕРКА: КИТАРА ЛИ Е? -->
                    @if (Model.Category.Name.Contains("Guitar") || Model.Category.Name.Contains("Bass"))
                    {
                        <li>
                            <div class="feature-icon"><i class="fa-solid fa-guitar"></i></div>
                            <strong>Body:</strong>&nbsp; @Model.Category.Name
                        </li>
                        <li>
                            <div class="feature-icon"><i class="fa-solid fa-hand"></i></div>
                            <strong>Orientation:</strong>&nbsp; @Model.Orientation
                        </li>
                        <li>
                            <div class="feature-icon"><i class="fa-solid fa-bolt"></i></div>
                            <strong>Electronics:</strong>&nbsp; @Model.PickupType Pickups
                        </li>
                        <li>
                            <div class="feature-icon"><i class="fa-solid fa-music"></i></div>
                            <strong>Strings:</strong>&nbsp; @Model.NumberOfStrings Strings
                        </li>
                        <li>
                            <div class="feature-icon"><i class="fa-solid fa-bridge"></i></div>
                            <strong>Bridge:</strong>&nbsp; @Model.BridgeType
                        </li>
                    }
                    else
                    {
                        <!-- 3. АКО НЕ Е КИТАРА (Усилвател/Аксесоар) -->
                        <li>
                            <div class="feature-icon"><i class="fa-solid fa-layer-group"></i></div>
                            <strong>Category:</strong>&nbsp; @Model.Category.Name
                        </li>

                        @if (!string.IsNullOrEmpty(Model.SubType))
                        {
                            <li>
                                <div class="feature-icon"><i class="fa-solid fa-filter"></i></div>
                                <strong>Type:</strong>&nbsp; @Model.SubType
                            </li>
                        }
                    }
                </ul>
                
            </div>
        </div>

        <!-- BOTTOM: TABS (OVERVIEW & SPECS) -->
        <div class="row">
            <div class="col-12">
                <ul class="nav nav-tabs" id="productTab" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active" id="overview-tab" data-bs-toggle="tab" data-bs-target="#overview" type="button">Overview</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" id="specs-tab" data-bs-toggle="tab" data-bs-target="#specs" type="button">Full Specs</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews" type="button">
                            Reviews (@(Model.Reviews?.Count ?? 0))
                        </button>
                    </li>
                </ul>
                <div class="tab-content" id="productTabContent">

                    <!-- OVERVIEW TAB -->
                    <div class="tab-pane fade show active" id="overview">
                        <div class="row mt-4">
                            <div class="col-lg-8">
                                @if (!string.IsNullOrEmpty(Model.Overview))
                                {
                                    @Html.Raw(Model.Overview)
                                }
                                else
                                {
                                    <p>@Model.Description</p>
                                    <p>Experience the legendary tone and playability that has made @Model.Brand a staple in the music industry. Built with precision and high-quality materials, this instrument is designed to inspire.</p>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- SPECS TAB -->
                    <div class="tab-pane fade" id="specs">
                        <div class="row mt-4">
                            <!-- ЛЯВО: Основните параметри -->
                            <div class="col-md-5 mb-4">
                                <h5 class="text-uppercase text-muted mb-3 border-bottom border-secondary pb-2">Key Features</h5>

                                <table class="table table-borderless spec-table">
                                    <tbody>
                                        <tr><th>Brand</th><td>@Model.Brand</td></tr>
                                        <tr><th>Model</th><td>@Model.Name</td></tr>
                                        <tr><th>Category</th><td>@Model.Category?.Name</td></tr>

                                        <!-- ПОКАЗВАМЕ ТЕЗИ САМО АКО Е КИТАРА -->
                                        @if (Model.Category.Name.Contains("Guitar") || Model.Category.Name.Contains("Bass"))
                                        {
                                            <tr><th>Orientation</th><td>@Model.Orientation</td></tr>
                                            <tr><th>Strings</th><td>@Model.NumberOfStrings</td></tr>
                                            <tr><th>Pickups</th><td>@Model.PickupType</td></tr>
                                            <tr><th>Bridge</th><td>@Model.BridgeType</td></tr>
                                        }

                                        <!-- АКО Е УСИЛВАТЕЛ ИЛИ ДРУГО - НЯМА ДА ИМА ИЗЛИШНИ РЕДОВЕ -->
                                    </tbody>
                                </table>
                            </div>

                            <!-- ДЯСНО: Детайлният списък (от новото поле) -->
                            <div class="col-md-7">
                                <h5 class="text-uppercase text-muted mb-3 border-bottom border-secondary pb-2">Technical Specifications</h5>

                                @if (!string.IsNullOrEmpty(Model.SpecsText))
                                {
                                    <ul class="list-unstyled">
                                        <!-- Тук цепим текста на редове и правим списък -->
                                        @foreach (var line in Model.SpecsText.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            <li class="mb-2 pb-2 border-bottom border-secondary" style="border-color: #333 !important;">
                                                <!-- Малка бяла точка, центрирана вертикално -->
                                                <i class="fa-solid fa-circle text-white me-2" style="font-size: 5px; vertical-align: middle;"></i> @line
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="text-muted">No detailed specifications available for this product.</p>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- REVIEWS TAB -->
                    <div class="tab-pane fade" id="reviews">
                        <div class="row mt-4">

                            <!-- ЛЯВО: СПИСЪК С РЕВЮТА -->
                            <div class="col-lg-7 pe-lg-5">
                                <h4 class="text-uppercase fw-bold mb-4 border-bottom border-secondary pb-2">Customer Reviews</h4>

                                @if (Model.Reviews != null && Model.Reviews.Any())
                                {
                                    var reviewsList = Model.Reviews.OrderByDescending(r => r.CreatedAt).ToList();

                                    // Извеждаме всички ревюта
                                    for (int i = 0; i < reviewsList.Count; i++)
                                    {
                                        var review = reviewsList[i];
                                        // Първите 2 са винаги видими. Останалите получават клас 'hidden-review'
                                        string hiddenClass = (i >= 2) ? "hidden-review" : "";

                                        <div class="review-item mb-4 pb-3 border-bottom border-dark @hiddenClass">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <div>
                                                    <!-- Звезди -->
                                                    <div class="text-warning small">
                                                        @for (int s = 1; s <= 5; s++)
                                                        {
                                                            if (s <= review.Rating)
                                                            {
                                                                <i class="fa-solid fa-star"></i>
                                                            }
                                                            else
                                                            {

                                                                <i class="fa-regular fa-star text-muted"></i>
                                                            }
                                                        }
                                                    </div>
                                                    <span class="fw-bold text-white">@review.User.Email.Split('@')[0]</span>
                                                </div>
                                                <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                                            </div>
                                            <p class="mt-2 text-light review-text mb-0" style="line-height: 1.6;">@review.Comment</p>
                                        </div>
                                    }

                                    // Бутон SHOW MORE (само ако има повече от 2 ревюта)
                                    @if (reviewsList.Count > 2)
                                    {
                                        <div class="text-center mt-4">
                                            <button type="button" id="toggleReviewsBtn" class="btn-toggle-reviews">
                                                Read All @reviewsList.Count Reviews <i class="fa-solid fa-chevron-down ms-2"></i>
                                            </button>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="alert bg-dark border-secondary text-center py-5">
                                        <i class="fa-regular fa-comment-dots fa-3x text-muted mb-3"></i>
                                        <h5 class="text-white">No reviews yet.</h5>
                                        <p class="text-muted mb-0">Be the first to share your thoughts about this gear!</p>
                                    </div>
                                }
                            </div>

                            <!-- ДЯСНО: ФОРМА ЗА ПИСАНЕ (Sticky) -->
                            <div class="col-lg-5 mt-5 mt-lg-0">
                                <div class="sticky-review-form">

                                    @if (Context.Session.GetInt32("UserID") != null)
                                    {
                                        <div class="p-4 bg-dark border border-secondary rounded shadow-sm">
                                            <h5 class="text-uppercase fw-bold mb-3 border-bottom border-secondary pb-2">Write a Review</h5>

                                            <form asp-action="AddReview" method="post">
                                                <input type="hidden" name="productId" value="@Model.ProductID" />

                                                <div class="mb-3">
                                                    <label class="form-label text-muted small fw-bold text-uppercase">Rating</label>
                                                    <select name="rating" class="form-select bg-black text-white border-secondary">
                                                        <option value="5">⭐⭐⭐⭐⭐ (5/5) - Excellent</option>
                                                        <option value="4">⭐⭐⭐⭐ (4/5) - Very Good</option>
                                                        <option value="3">⭐⭐⭐ (3/5) - Good</option>
                                                        <option value="2">⭐⭐ (2/5) - Fair</option>
                                                        <option value="1">⭐ (1/5) - Poor</option>
                                                    </select>
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label text-muted small fw-bold text-uppercase">Your Review</label>
                                                    <textarea name="comment"
                                                          id="reviewInput"
                                                          class="form-control bg-black text-white border-secondary"
                                                          rows="4"
                                                          required
                                                          maxlength="900"
                                                          placeholder="What do you love about it?"
                                                          style="resize: vertical; max-height: 250px;"
                                                          oninput="updateCharCount(this)"></textarea>

                                                    <div class="text-end mt-1">
                                                        <small class="text-muted" id="charCount">0 / 900</small>
                                                    </div>
                                                </div>

                                                <button type="submit" class="btn btn-danger w-100 text-uppercase fw-bold py-2">
                                                    Submit Review
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <!-- Ако не е логнат -->
                                        <div class="p-4 bg-dark border border-secondary rounded text-center">
                                            <h5 class="text-uppercase fw-bold mb-3">Want to leave a review?</h5>
                                            <p class="text-muted small">You must be logged in to share your opinion with the community.</p>
                                            <a href="@Url.Action("Login", "Account")" class="btn btn-outline-light w-100 text-uppercase fw-bold">
                                                Log In / Register
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
