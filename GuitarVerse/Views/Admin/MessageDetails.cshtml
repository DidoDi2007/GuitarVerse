@model GuitarVerse.Models.SupportMessage
@{
    ViewData["Title"] = "Message Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    // Взимаме ролята директно от сесията
    var userRole = HttpContextAccessor.HttpContext.Session.GetString("UserRole");
    var isSuperAdmin = userRole == "superadmin"; // Проста проверка

    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}

<div class="mb-4">
    <a href="@Url.Action("Support")" class="text-muted text-decoration-none"><i class="fa-solid fa-arrow-left"></i> Back to Inbox</a>
</div>

<div class="row">
    <!-- MESSAGE CARD -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-4">

            <!-- Хедър на съобщението -->
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
                <div>
                    <h5 class="fw-bold mb-1">@Model.Subject</h5>
                    <div class="text-muted small">
                        From: <strong>@Model.SenderName</strong> &lt;@Model.SenderEmail&gt;
                    </div>
                </div>
                <div class="text-muted small">
                    <i class="fa-regular fa-clock me-1"></i> @Model.CreatedAt.ToString("f")
                </div>
            </div>

            <!-- ТЯЛО НА СЪОБЩЕНИЕТО (Подобрен дизайн) -->
            <div class="card-body">
                <label class="text-uppercase text-muted small fw-bold mb-2">Message Content:</label>

                <!-- Тук правим "кутията" за текста -->
                <div class="p-4 rounded" style="background-color: #f8f9fa; border-left: 4px solid #333; min-height: 150px; white-space: pre-wrap; font-size: 1rem; color: #333;">
                    @Model.MessageText
                </div>
            </div>
        </div>

        <!-- REPLY FORM -->
        @if (Model.Status != "Replied")
        {
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body">
                    <h6 class="fw-bold text-uppercase mb-3"><i class="fa-solid fa-reply"></i> Send Reply</h6>
                    <form asp-action="ReplyMessage" method="post">
                        <input type="hidden" name="id" value="@Model.MessageID" />

                        <div class="mb-3">
                            <!-- ОГРАНИЧАВАНЕ НА ПОЛЕТО -->
                            <textarea name="replyText"
                                  class="form-control bg-white"
                                  rows="6"
                                  placeholder="Type your answer here..."
                                  required
                                  style="resize: vertical; max-height: 400px; min-height: 150px;"></textarea>
                        </div>

                        <div class="text-end">
                            <button type="submit" class="btn btn-primary px-4 fw-bold">
                                Send Email <i class="fa-solid fa-paper-plane ms-2"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-success shadow-sm border-0">
                <h6 class="fw-bold"><i class="fa-solid fa-check-circle me-2"></i> Reply Sent</h6>
                <small class="text-muted d-block mb-2">You replied on @DateTime.Now.ToShortDateString():</small>
                <div class="p-3 bg-white rounded text-dark" style="font-style: italic;">
                    "@Model.ReplyText"
                </div>
            </div>
        }
    </div>

    <!-- SIDEBAR INFO -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="text-uppercase text-muted small fw-bold mb-3">Sender Details</h6>

                <!-- АВАТАР -->
                <div class="text-center mb-3">
                    <div style="width: 60px; height: 60px; background-color: #eee; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto; font-size: 1.5rem; color: #888;">
                        <i class="fa-solid fa-user"></i>
                    </div>
                    <h5 class="mt-2 mb-0 fw-bold">@Model.SenderName</h5>
                    <p class="text-muted small">@Model.SenderEmail</p>
                </div>

                <!-- СТАТУС НА АКАУНТА -->
                @if (Model.UserID != null)
                {
                    <div class="alert alert-success py-2 px-3 mb-3 small text-center">
                        <i class="fa-solid fa-check-circle me-1"></i> Registered Customer
                    </div>

                    @if (isSuperAdmin)
                    {
                        <a href="@Url.Action("Users", "Admin")" class="btn btn-outline-dark btn-sm w-100 mb-3">
                            <i class="fa-solid fa-magnifying-glass"></i> Find User
                        </a>
                    }
                }
                else
                {
                    <div class="alert alert-secondary py-2 px-3 mb-3 small text-center">
                        <i class="fa-solid fa-user-secret me-1"></i> Guest (Not Registered)
                    </div>
                }

               
            </div>
        </div>
    </div>
</div>