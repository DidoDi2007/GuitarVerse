@model List<GuitarVerse.Models.Artist>
@{
    ViewData["Title"] = "Manage Artists";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Artists</h2>
    <a href="@Url.Action("CreateArtist")" class="btn btn-dark">
        <i class="fa-solid fa-plus"></i> Add Artist
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="admin-table">
            <thead>
                <tr>
                    <th style="width: 80px;">Image</th>
                    <th>Name</th>
                    <th>Band</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var artist in Model)
                {
                    <tr>
                        <td>
                            <img src="@artist.CardImage" style="width: 50px; height: 50px; object-fit: cover; border-radius: 50%;">
                        </td>
                        <td class="fw-bold">@artist.Name</td>
                        <td class="text-muted">@artist.Band</td>
                        <td class="text-end">
                            <!-- EDIT BUTTON -->
                            <a href="@Url.Action("EditArtist", new { id = artist.ArtistID })" class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                <i class="fa-solid fa-pen"></i>
                            </a>

                            <!-- DELETE BUTTON -->
                            <form asp-action="DeleteArtist" method="post" onsubmit="return confirm('Delete this artist?');" style="display:inline;">
                                <input type="hidden" name="id" value="@artist.ArtistID" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>