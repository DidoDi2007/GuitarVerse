@model List<GuitarVerse.Models.PromoCode>
@{
    ViewData["Title"] = "Promo Codes";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="fw-bold mb-4">Promo Codes</h2>

<!-- ADD FORM -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h5 class="fw-bold text-muted text-uppercase mb-3">Create New Coupon</h5>
        <form asp-action="CreatePromo" method="post" class="row g-3">
            <div class="col-md-4">
                <input type="text" name="code" class="form-control text-uppercase fw-bold" placeholder="Code (e.g. METAL20)" required />
            </div>
            <div class="col-md-3">
                <div class="input-group">
                    <input type="number" name="percent" class="form-control" placeholder="Discount" min="1" max="100" required />
                    <span class="input-group-text">%</span>
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-dark w-100 fw-bold">CREATE</button>
            </div>
        </form>
    </div>
</div>

<!-- LIST -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Discount</th>
                    <th>Status</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td class="fw-bold text-primary">@p.Code</td>
                        <td>@p.DiscountPercent%</td>
                        <td><span class="badge bg-success">Active</span></td>
                        <td class="text-end">
                            <form asp-action="DeletePromo" method="post">
                                <input type="hidden" name="id" value="@p.PromoID" />
                                <button class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>