@model GuitarVerse.Models.ProductFormViewModel
@{
    ViewData["Title"] = "Add Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container" style="max-width: 900px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Add New Product</h2>
    </div>

    <form method="post" enctype="multipart/form-data" class="card border-0 shadow-sm">
        <div class="card-body p-4">

            <!-- Основна информация -->
            <h5 class="text-uppercase text-muted mb-3 border-bottom pb-2">Basic Info</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Brand</label>
                    <input asp-for="Product.Brand" class="form-control" placeholder="e.g. Fender" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Model Name</label>
                    <input asp-for="Product.Name" class="form-control" placeholder="e.g. Player Stratocaster" required />
                </div>

                <!-- 1. CATEGORY (ID: Product_CategoryID) -->
                <div class="col-md-4">
                    <label class="form-label fw-bold">Category</label>
                    <select asp-for="Product.CategoryID" class="form-select" id="Product_CategoryID">
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.CategoryID">@cat.Name</option>
                        }
                    </select>
                </div>

                <!-- 2. SUB-TYPE (ID: subTypeContainer, subTypeSelect) -->
                <div class="col-md-4" id="subTypeContainer" style="display:none;">
                    <label class="form-label fw-bold">Sub-Type</label>
                    <select asp-for="Product.SubType" class="form-select" id="subTypeSelect">
                        <option value="">-- Select Type --</option>
                        <!-- Опциите ще се генерират от скрипта -->
                    </select>
                </div>


                @* Падащо меню за артисти!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! *@
                <div class="col-md-4">
                    <label class="form-label fw-bold">Signature Artist (Optional)</label>
                    <select asp-for="Product.ArtistID" class="form-select">
                        <option value="">-- None --</option>
                        @if (Model.Artists != null)
                        {
                            @foreach (var artist in Model.Artists)
                            {
                                <option value="@artist.ArtistID">@artist.Name</option>
                            }
                        }
                    </select>
                </div>



                <div class="col-md-4">
                    <label class="form-label fw-bold">Price (€)</label>
                    <div class="input-group">
                        <span class="input-group-text">€</span>
                        <input asp-for="Product.Price" type="number" step="0.01" class="form-control" required />
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Stock</label>
                    <input asp-for="Product.Stock" type="number" class="form-control" value="1" required />
                </div>
            </div>

            <!-- Спецификации -->
            <div id="guitarSpecsContainer">
                <h5 class="text-uppercase text-muted mb-3 border-bottom pb-2 mt-4">Specifications</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <label class="form-label text-muted small">Strings</label>
                        <input asp-for="Product.NumberOfStrings" type="number" class="form-control" value="6" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small">Orientation</label>
                        <select asp-for="Product.Orientation" class="form-select">
                            <option>Right-Handed</option>
                            <option>Left-Handed</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small">Pickups</label>
                        <select asp-for="Product.PickupType" class="form-select">
                            <option>Passive</option>
                            <option>Active</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small">Bridge</label>
                        <select asp-for="Product.BridgeType" class="form-select">
                            <option>Fixed</option>
                            <option>Tremolo</option>
                            <option>Floyd Rose</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Снимки -->
            <h5 class="text-uppercase text-muted mb-3 border-bottom pb-2 mt-4">Images</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Main Image (Cover)</label>
                    <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" required />
                    <div class="form-text">This will be shown in the catalog.</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Gallery Images (Max 5)</label> <!-- Промених текста -->
                    <input asp-for="GalleryFiles" type="file" class="form-control" accept="image/*" multiple />

                    <!-- ТОВА ЩЕ ПОКАЖЕ ГРЕШКАТА В ЧЕРВЕНО -->
                    <span asp-validation-for="GalleryFiles" class="text-danger small"></span>

                    <div class="form-text">Select up to 5 images for the details page (Ctrl + Click).</div>
                </div>
            </div>

            <!-- Описание -->
            <h5 class="text-uppercase text-muted mb-3 border-bottom pb-2 mt-4">Description</h5>
            <div class="mb-3">
                <label class="form-label fw-bold">Short Description</label>
                <input asp-for="Product.Description" class="form-control" placeholder="Brief summary..." />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Detailed Specs (One per line)</label>
                @* <textarea asp-for="Product.SpecsText" class="form-control" rows="8" placeholder="Body: Alder&#10;Neck: Maple&#10;Fretboard: Ebony&#10;..."></textarea> *@

                <textarea name="Product.SpecsText"
                          class="form-control"
                          rows="8"
                          placeholder="Body: Alder&#10;Neck: Maple&#10;Fretboard: Ebony&#10;..."
                          required
                          style="resize: vertical; max-height: 400px; min-height: 150px;"></textarea>

                <div class="form-text">Enter each specification on a new line.</div>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Full Overview</label>
                @* <textarea asp-for="Product.Overview" class="form-control font-monospace" rows="6" placeholder="..."></textarea> *@

                <textarea name="Product.Overview"
                          class="form-control font-monospace"
                          rows="6"
                          placeholder="...."
                          required
                          style="resize: vertical; max-height: 400px; min-height: 150px;"></textarea>

            </div>

            <div class="text-end pt-3">
                <button type="submit" class="btn btn-dark px-5 py-2 fw-bold text-uppercase">Save Product</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // 1. Дефиниране на елементите
            const categorySelect = document.getElementById("Product_CategoryID");
            const guitarSpecs = document.getElementById("guitarSpecsContainer");
            const subTypeContainer = document.getElementById("subTypeContainer");
            const subTypeSelect = document.getElementById("subTypeSelect");

            // 2. Дефиниране на опциите
            const subTypes = {
                "amp": ["Combo Amp", "Amp Head", "Cabinet", "Processor"],
                "accessory": ["Strings", "Picks", "Cables", "Case", "Strap", "Stand"]
            };

            // 3. Взимаме текущата стойност от Базата (ако е Edit)
            // Тъй като сме вътре в CSHTML, можем да ползваме @Model
            const savedSubType = "@Html.Raw(Model.Product?.SubType ?? "")";

            function toggleFields() {
                // Взимаме избрания текст и го правим на малки букви (напр. "Electric Guitars" -> "electric guitars")
                const selectedText = categorySelect.options[categorySelect.selectedIndex].text.toLowerCase();

                // Нулираме
                guitarSpecs.style.display = "none";
                subTypeContainer.style.display = "none";

                // Логика
                if (selectedText.includes("guitar") || selectedText.includes("bass")) {
                    // АКО Е КИТАРА
                    guitarSpecs.style.display = "block";
                }
                else if (selectedText.includes("amp")) {
                    // АКО Е УСИЛВАТЕЛ
                    subTypeContainer.style.display = "block";
                    updateSubMenu(subTypes["amp"]);
                }
                else if (selectedText.includes("accessori") || selectedText.includes("accessory")) {
                    // АКО Е АКСЕСОАР
                    subTypeContainer.style.display = "block";
                    updateSubMenu(subTypes["accessory"]);
                }
            }

            // Функция за пълнене на менюто
            function updateSubMenu(items) {
                // Изчистваме старите опции
                subTypeSelect.innerHTML = '<option value="">-- Select Type --</option>';

                items.forEach(item => {
                    const option = document.createElement("option");
                    option.value = item;
                    option.text = item;

                    // ПРОВЕРКА: Ако това е запазената стойност, избираме я
                    if (item === savedSubType) {
                        option.selected = true;
                    }

                    subTypeSelect.appendChild(option);
                });
            }

            // Слушател за промяна
            categorySelect.addEventListener("change", function() {
                // Ако сменим категорията ръчно, не искаме да се избира старата стойност автоматично
                // (освен ако логиката не го изисква, но тук е по-чисто така)
                toggleFields();
            });

            // Първоначално стартиране
            toggleFields();
        });
    </script>
}