@model List<GuitarVerse.Models.Order>
@{
    ViewData["Title"] = "My Orders";
}


<div class="profile-wrapper">
    <div class="container">
        <h2 class="text-uppercase fw-bold mb-4">My Order History</h2>

        @if (!Model.Any())
        {
            <div class="alert alert-dark text-center py-5">
                <h4>No completed orders found.</h4>
                <a href="@Url.Action("Index", "Shop")" class="btn btn-light mt-3 text-uppercase fw-bold">Start Shopping</a>
            </div>
        }
        else
        {
            <div class="row">
                @foreach (var order in Model)
                {
                    <div class="col-12 mb-4">
                        <div class="card bg-dark border-secondary">

                            <!-- HEADER -->
                            <div class="card-header border-secondary d-flex justify-content-between align-items-center py-3">
                                <div>
                                    <span class="text-muted small text-uppercase">Order Placed</span><br>
                                    <span class="fw-bold">@order.OrderDate.ToString("dd MMM yyyy")</span>
                                </div>
                                <div>
                                    <span class="text-muted small text-uppercase">Total</span><br>
                                    <span class="fw-bold text-white">@order.TotalAmount.ToString("N2") €</span>
                                </div>
                                <div>
                                    <span class="text-muted small text-uppercase">Order #</span><br>
                                    <span class="text-white">@order.OrderID</span>
                                </div>
                            </div>

                            <div class="card-body" style="background-color: #212529;">
                                <!-- Задаваме цвят, за да пасне на иконите -->
                                <!-- STATUS TRACKER -->
                                @{
                                    var status = order.Status;
                                    var isPaid = true;
                                    var isShipped = status == "Shipped" || status == "Delivered";
                                    var isDelivered = status == "Delivered";
                                }

                                <div class="steps px-3">
                                    <div class="step @(isPaid ? "active" : "")">
                                        <div class="step-icon"><i class="fa-solid fa-check-circle"></i></div>
                                        <div class="step-text">Paid</div>
                                    </div>
                                    <div class="step @(isShipped ? "active" : "")">
                                        <div class="step-icon"><i class="fa-solid fa-truck-fast"></i></div>
                                        <div class="step-text">Shipped</div>
                                    </div>
                                    <div class="step @(isDelivered ? "active" : "")">
                                        <div class="step-icon"><i class="fa-solid fa-box-open"></i></div>
                                        <div class="step-text">Delivered</div>
                                    </div>
                                </div>

                                <hr class="border-secondary my-4">

                                <!-- PRODUCTS & TRACKING -->
                                <div class="row">

                                    <!-- ЛЯВО: Списък с продукти -->
                                    <div class="col-md-8 border-end border-secondary">
                                        <h6 class="text-uppercase text-muted small mb-3">Items in this shipment</h6>

                                        @foreach (var detail in order.OrderDetails)
                                        {
                                            <div class="d-flex align-items-center mb-3">
                                                <!-- Снимка -->
                                                <img src="@detail.Product.ImagePath" style="width: 60px; height: 60px; object-fit: contain; background: #fff; border-radius: 4px; padding: 2px;" class="me-3">

                                                <!-- Име и Бройка -->
                                                <div class="flex-grow-1">
                                                    <div class="fw-bold text-white">@detail.Product.Name</div>
                                                    <div class="text-muted small">Brand: @detail.Product.Brand</div>
                                                </div>

                                                <!-- ЦЕНА И БРОЙКА (НОВО) -->
                                                <div class="text-end ms-3">
                                                    <div class="fw-bold text-white">@detail.Price.ToString("N2") €</div>
                                                    <div class="text-muted small">x @detail.Quantity</div>
                                                </div>
                                            </div>
                                        }
                                    </div>

                                    <!-- ДЯСНО: Проследяване -->
                                    <div class="col-md-4 ps-md-4 mt-3 mt-md-0 d-flex flex-column justify-content-center">
                                        @if (!string.IsNullOrEmpty(order.TrackingNumber))
                                        {
                                            <div class="text-center">
                                                <div class="mb-3">
                                                    <small class="text-muted text-uppercase">Tracking Number</small><br>
                                                    <span class="fs-5 font-monospace text-info">@order.TrackingNumber</span>
                                                </div>

                                                <button onclick="showTrackingDemo('@order.TrackingNumber')" class="btn btn-outline-light w-100">
                                                    <i class="fa-solid fa-magnifying-glass-location me-2"></i> Track Package
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="text-center text-muted py-3">
                                                <i class="fa-solid fa-box-archive fa-2x mb-2"></i><br>
                                                <span>Processing Order...</span>
                                            </div>
                                        }
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="mt-4">
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Back to Profile</a>
            </div>
        }

        <!-- DEMO TRACKING MODAL -->
        <div class="modal fade" id="trackingModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content bg-dark text-white border-secondary">
                    <div class="modal-header border-secondary">
                        <h5 class="modal-title fw-bold"><i class="fa-solid fa-cube text-warning me-2"></i>Project Demo</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-center py-4">
                        <i class="fa-solid fa-truck-fast fa-3x text-muted mb-3"></i>
                        <h4 class="fw-bold">Package is in Transit</h4>
                        <p class="text-muted">
                            This is a demonstration environment. In a real-world scenario,
                            this button would redirect to the courier's tracking page.
                        </p>
                        <div class="alert alert-info d-inline-block mt-2">
                            Simulated Tracking #: <strong id="modalTrackingNum"></strong>
                        </div>
                    </div>
                    <div class="modal-footer border-secondary">
                        <button type="button" class="btn btn-light w-100" data-bs-dismiss="modal">Understood</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

